        <mxCell id="bfBZxff8J3gGZJA35PTy-49" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=20;fillColor=light-dark(#FFFFFF,#DFB3B3);fontColor=light-dark(#000000,#000000);strokeColor=light-dark(#000000,#0B0B0B);verticalAlign=top;align=left;arcSize=0;spacingLeft=5;spacingRight=5;spacingTop=5;spacingBottom=5;" value="&lt;div class=&quot;pointer-events-none absolute inset-x-4 top-12 bottom-4&quot;&gt;&lt;div class=&quot;pointer-events-none sticky z-40 shrink-0 z-1!&quot;&gt;&lt;div class=&quot;sticky bg-token-border-light&quot;&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;pointer-events-none absolute inset-x-px top-6 bottom-6&quot;&gt;&lt;div class=&quot;sticky z-1!&quot;&gt;&lt;div class=&quot;bg-token-bg-elevated-secondary sticky&quot;&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;corner-superellipse/1.1 rounded-3xl bg-token-bg-elevated-secondary&quot;&gt;&lt;div class=&quot;relative z-0 flex max-w-full&quot;&gt;&lt;div id=&quot;code-block-viewer&quot; dir=&quot;ltr&quot; class=&quot;q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy&quot;&gt;&lt;div class=&quot;cm-scroller&quot;&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;✔ All positive pairs → target = 1&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;✔ All negative pairs → target = 0&lt;/div&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;code data-start=&quot;326&quot; data-end=&quot;339&quot; style=&quot;background-color: transparent;&quot;&gt;(hea, city)&lt;/code&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; → seen in window → &lt;/span&gt;&lt;strong data-start=&quot;359&quot; data-end=&quot;373&quot; style=&quot;background-color: transparent;&quot;&gt;target = 1&lt;/strong&gt;&lt;/li&gt;&lt;li&gt;&lt;code data-start=&quot;376&quot; data-end=&quot;388&quot; style=&quot;background-color: transparent;&quot;&gt;(hea, old)&lt;/code&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; → sampled negative → &lt;/span&gt;&lt;strong data-start=&quot;410&quot; data-end=&quot;424&quot; style=&quot;background-color: transparent;&quot;&gt;target = 0&lt;/strong&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Note&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;In more advanced models&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;b style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;→&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp;targets may be probabilities&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;→&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;or full softmax distributions&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;→&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;or masked-token prediction&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;→&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;In skip-gram training with negative sampling, positive context pairs are assigned target 1, while sampled negative pairs are assigned target 0.&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
