        <mxCell id="bfBZxff8J3gGZJA35PTy-50" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=20;fillColor=light-dark(#FFFFFF,#DFB3B3);fontColor=light-dark(#000000,#000000);strokeColor=light-dark(#000000,#0B0B0B);verticalAlign=top;align=left;arcSize=0;spacingLeft=5;spacingRight=5;spacingTop=5;spacingBottom=5;" value="hea_new = hea + η * error * city&lt;br data-start=&quot;972&quot; data-end=&quot;975&quot;&gt;city_new = city + η * error * hea&lt;br&gt;&lt;br&gt;η (eta) → learning rate&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; →&amp;nbsp;&lt;span data-start=&quot;995&quot; data-end=&quot;1013&quot;&gt;step size knob&lt;/span&gt; of learning&lt;br&gt;&lt;br&gt;&lt;p data-start=&quot;186&quot; data-end=&quot;206&quot;&gt;For word embeddings:&lt;br&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;0.1  → very aggressive learning&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;0.01 → common default&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;0.001 → conservative&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" vertex="1">
