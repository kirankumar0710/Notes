        <mxCell id="YbeNFDlLrJjwLAD1uiBH-8" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#99CCFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontSize=20;fontColor=light-dark(#000000,#000000);" value="&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 153));&quot;&gt;&lt;b&gt;Step 7&lt;/b&gt;&lt;/font&gt;&lt;div&gt;Compute Attention Scores&lt;br&gt;&lt;/div&gt;" vertex="1">
