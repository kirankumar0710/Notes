uot;&gt;bank = river side&lt;/em&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;, not &lt;/span&gt;&lt;em data-start=&quot;660&quot; data-end=&quot;683&quot; style=&quot;background-color: transparent;&quot;&gt;financial institution&lt;/em&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
